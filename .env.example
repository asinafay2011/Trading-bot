# Copy this file to .env and fill in your credentials
# Alpaca API credentials
ALPACA_KEY_ID=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret

# Set to true for paper trading, false for live trading
PAPER_TRADING=true

# Discord webhook URL (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Strategy: "trend" (SMA20>SMA50 + RSI<70) or "donchian" (20-bar high breakout
# + volume confirmation). Defaults to "trend" if unset.
STRATEGY=trend

# Optional auto-switch from trend → donchian on this UTC date (YYYY-MM-DD).
# Ignored when STRATEGY is set explicitly. Useful for "run trend two weeks,
# then donchian for a month" without manual flip.
# STRATEGY_SWITCH_DATE=2026-05-06

